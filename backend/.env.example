APP_NAME=OpsSage AI
APP_VERSION=1.1.0
DEBUG=false

# Keep this disabled for the public portfolio deployment.
# Replace it only inside a secure production environment.
OPENAI_API_KEY=public-demo-disabled
OPENAI_MODEL=gpt-4.1-mini

# Leave empty to disable protected AI execution endpoints.
# Generate a long random value in Render for production.
OPSSAGE_API_KEY=

RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
